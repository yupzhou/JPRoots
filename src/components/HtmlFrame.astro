---
// src/components/HtmlFrame.astro
export interface Props {
  src: string; // 传入相对路径，如 "/html/liber.html"
  title?: string;
}

const { src, title = "IFrame Content" } = Astro.props;
const base = import.meta.env.BASE_URL;
const finalSrc = base.replace(/\/$/, "") + src;
---

<iframe src={finalSrc} title={title} style="width:100%;height:80vh;border:none;"
></iframe>
