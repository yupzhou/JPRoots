---
// src/layouts/FullWidthLayout.astro
---

<html lang="zh-CN" class="sl-theme-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{Astro.props.frontmatter?.title ?? "JPRoots"}</title>
    <slot name="head" />
  </head>
  <body>
    <!-- 完全保留 Starlight 的原始结构 -->
    <div id="starlight-app">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* 让 iframe 在 Starlight 的默认布局中全宽 */
  .sl-markdown-content iframe {
    width: 100% !important;
    min-height: 85vh !important;
    border: none !important;
    display: block !important;
    background: white !important;
  }

  div#starlight-app {
    margin: 0 !important;
  }

  body {
    font-family: var(--sl-font) !important;
  }
</style>
